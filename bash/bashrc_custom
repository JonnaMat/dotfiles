charm() {
    if [ "$1" ]; then
        charm_command="bash /home/jonna/pycharm-2025.2.1.1/bin/pycharm.sh ${1}"
    else
        charm_command="bash /home/jonna/pycharm-2025.2.1.1/bin/pycharm.sh"
    fi
    tmux has-session -t pycharm-session 2>/dev/null
    if [ $? != 0 ]; then
      tmux new-session -d -s pycharm-session "$charm_command"
    else
      $charm_command
    fi
    exit
}


# --- GIT ----------------------------------------------------------------------

alias gca="git commit --amend --no-edit"
alias gc="git commit"

alias grh="git reset --hard origin"
alias gp="git pull"
alias grc="git rebase --continue"

alias p="git push origin HEAD:refs/for/master --signed"
alias gs="git stash"
alias gp="git pull"

gpf() {
  git reset --hard origin
  git pull
}

# undo last commit but keep changes
gundo() {
  git reset HEAD^
}

gcm() {
    git checkout master
    git pull
}

gcmf() {
    git stash
    git checkout master
    git reset --hard origin
    git pull
}

gri() {
   if [ "$1" ]; then
        git rebase -i HEAD~$1
    else
        echo "Argument missing: git rebase -i HEAD~\$1"
    fi
}

