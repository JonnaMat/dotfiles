# --- KUBECTL ------------------------------------------------------------------

kc.help() {
  echo "alias kc='kubectl'"
  echo "alias kcj='kc get jobs'"
  echo "alias kcp='kc get pods'"
  echo "alias kc.events='kc get events -w'"
  echo "kcd (delete job)"
  echo "kce <pod name>"
  echo "kc.start <.yaml>"
  echo "kc.logs <pod name>"
}


alias kc="kubectl"
alias kubectl.help="kc.help"
alias kcj="kc get jobs"
alias kcp="kc get pods"
alias kc.events="kc get events -w"

kcd() {
  kcj

  read -r -p "Select job to delete: " response
    case "$response" in
        [N])
            return 1
            ;;
        *)
            kc delete job $response
            return 0
            ;;
    esac
}

kc.start() {
  echo "\$1 is the name of the '.yaml'"
  ls
  # helm template . --dry-run=server --values $1 | kubectl create -f-
  helm template /home/jonna/src/embedl/ci/helm-charts/training-job/ --values $1 | kubectl create -f-
}

kce() {
  echo "kc (kubectl) get pods"
  kc get pods
  kc exec -it $1 -- bash
}

kc.logs() {
  kcp
  kc logs $1
}

kc.scp() {
  kcp
  echo "kubectl cp jonna/<podNAME>:<remote dir> <local dir>"
}

# --- CLAUDE ---------------------------------------------

og_claude() {
  command claude "$@"
}

claude() {

   if [ -n "$TMUX" ]; then
      command claude --dangerously-skip-permissions --remote-control "$@"
    else
      tmux new-session -s claude -- command claude --dangerously-skip-permissions --remote-control "$@"
    fi
}
